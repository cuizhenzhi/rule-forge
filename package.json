{
  "name": "ruleforge",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev -w @ruleforge/server",
    "dev:web": "npm run dev -w @ruleforge/web",
    "test": "npm run test -w @ruleforge/dsl-core",
    "build:core": "npm run build -w @ruleforge/dsl-core",
    "import:toxicn": "npx tsx packages/server/src/scripts/import-toxicn.ts",
    "baseline:rules": "npx tsx packages/server/src/scripts/run-rule-baseline.ts",
    "register:bert": "npx tsx packages/server/src/scripts/register-bert-baseline.ts",
    "gen:candidates": "npx tsx packages/server/src/scripts/generate-rule-candidates.ts",
    "eval:candidates": "npx tsx packages/server/src/scripts/evaluate-rule-candidates.ts",
    "select:v2": "npx tsx packages/server/src/scripts/select-rule-set-v2.ts",
    "test:v2": "npx tsx packages/server/src/scripts/run-rule-set-v2-test.ts",
    "fusion:baseline": "npx tsx packages/server/src/scripts/run-fusion-baseline.ts",
    "ablations": "npx tsx packages/server/src/scripts/run-ablations.ts"
  },
  "engines": {
    "node": ">=20"
  }
}
